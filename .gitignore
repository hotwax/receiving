# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*
.env
.env.*
playwright/.env
playwright/.env.*
playwright/.auth/*.json
**/storageState.json
**/*.storageState.json
playwright/data/**/secrets*
playwright/data/**/credentials*
playwright/data/**/*.secret.*

/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode
/coverage
/dist
/node_modules
/platforms
/plugins
/www

# Excluding the .env.example file from .gitignore
!.env.example

.firebase
.history
