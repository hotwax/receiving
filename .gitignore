# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*
*.md
.env
.env.*
playwright/.env
playwright/.env.*
playwright/.auth/*.json
playwright/.auth/state*.json
**/storageState.json
**/*.storageState.json
playwright/data/**/secrets*
playwright/data/**/credentials*
playwright/data/**/*.secret.*
playwright/data/**/*.credentials.*
playwright/test-results/
playwright/playwright-report/
playwright/blob-report/
playwright/.playwright/
playwright/screenshots/
playwright/screenshot/
test-results/
playwright-report/
blob-report/
.playwright/
*.trace.zip
screenshots/
screenshot/
/data/
**/screenshots/
**/screenshot/
**/data/

/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode
/coverage
/dist
/node_modules
/platforms
/plugins
/www

# Excluding the .env.example file from .gitignore
!.env.example

.firebase
.history
